78. Backtracking - Word Search in a Grid


import java.io.*;
import java.util.*;

public class Solution {

    static int m, n;
    static char[][] board;
    static boolean[][] visited;

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        m = sc.nextInt();
        n = sc.nextInt();
        sc.nextLine();

        board = new char[m][n];

        for (int i = 0; i < m; i++) {
            String line = sc.nextLine();
            for (int j = 0; j < n; j++) {
                board[i][j] = line.charAt(j);
            }
        }

        String word = sc.nextLine();

        visited = new boolean[m][n];

        boolean found = false;

        for (int i = 0; i < m && !found; i++) {
            for (int j = 0; j < n && !found; j++) {
                if (dfs(i, j, word, 0)) {
                    found = true;
                }
            }
        }

        System.out.println(found);
    }

    static boolean dfs(int i, int j, String word, int index) {
        // If all characters matched
        if (index == word.length()) return true;

        // Boundary + mismatch + visited check
        if (i < 0 || j < 0 || i >= m || j >= n ||
            visited[i][j] || board[i][j] != word.charAt(index)) {
            return false;
        }

        // Mark visited
        visited[i][j] = true;

        // Explore 4 directions
        boolean found = dfs(i + 1, j, word, index + 1) ||
                        dfs(i - 1, j, word, index + 1) ||
                        dfs(i, j + 1, word, index + 1) ||
                        dfs(i, j - 1, word, index + 1);

        // Backtrack
        visited[i][j] = false;

        return found;
    }
}
