import java.io.*;
import java.util.*;

public class Solution {
    
    static boolean validatePattern(String in, String p) {
        int in_len = in.length();
        int p_len = p.length();
        
        boolean[][] match = new boolean[in_len + 1][p_len + 1];
        
        // Base case
        match[0][0] = true;
        
        // Handle patterns like *, **, ***
        for (int j = 1; j <= p_len; j++) {
            if (p.charAt(j - 1) == '*') {
                match[0][j] = match[0][j - 1];
            }
        }
        
        for (int i = 1; i <= in_len; i++) {
            for (int j = 1; j <= p_len; j++) {
                
                char in_c = in.charAt(i - 1);
                char p_c = p.charAt(j - 1);
                
                if (p_c == in_c || p_c == '?') {
                    match[i][j] = match[i - 1][j - 1];
                } 
                else if (p_c == '*') {
                    match[i][j] = match[i][j - 1]   // '*' = empty
                               || match[i - 1][j];  // '*' = one/more chars
                } 
                else {
                    match[i][j] = false;
                }
            }
        }
        
        return match[in_len][p_len];
    }

    public static void main(String[] args) {
        
        Scanner sc = new Scanner(System.in);
        
        String input = sc.nextLine().trim();
        String pattern = sc.nextLine().trim();
        
        boolean isMatching = validatePattern(input, pattern);
        
        System.out.println(isMatching);
    }
}
