49. Greedy Algorithm - Consolidating Meeting Time Slots


import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        
        Scanner sc=new Scanner(System.in);
        
        int n=sc.nextInt();
        
       int[][] intervals=new int[n][2];
        
        for(int i=0;i<n;i++)
        {
            intervals[i][0]=sc.nextInt();
            intervals[i][1]=sc.nextInt();

        }
        //4
        /*
        7 8
        1 5
        2 4
        4 6
        */
        
        
        Arrays.sort(intervals,(a,b)->a[0]-b[0]);
        /*
        1 5
        2 4
        4 6
        7 8
        */
        
        int start=intervals[0][0];//1 //7
        int end=intervals[0][1];//5 6 //8
        
        for(int i=1;i<n;i++)//1 2 3 //1 2 3
        {
            if(intervals[i][0] <=end)//7 <=6 fail 
            {
                end=Math.max(end,intervals[i][1]);//math.max(5,6)=6
            }
            else
            {
                System.out.println(start+" "+end);//1 6
                start=intervals[i][0];//7
                end=intervals[i][1];//8
            }
        }
        System.out.println(start+" "+end);//7 8
    }
}
