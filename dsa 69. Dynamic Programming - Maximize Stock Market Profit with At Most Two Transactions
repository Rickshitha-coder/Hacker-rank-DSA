69. Dynamic Programming - Maximize Stock Market Profit with At Most Two Transactions

import java.io.*;
import java.util.*;

public class Solution {

    
    static int findMaxProfit(int[] prices, int n) {

        if (n == 0) return 0;

        int[] left = new int[n];
        int[] right = new int[n];

        //left to right
        int minPrice = prices[0];
        for (int i = 1; i < n; i++) {
            minPrice = Math.min(minPrice, prices[i]);
            left[i] = Math.max(left[i - 1], prices[i] - minPrice);
        }

        
        int maxPrice = prices[n - 1];
        for (int i = n - 2; i >= 0; i--) {
            maxPrice = Math.max(maxPrice, prices[i]);
            right[i] = Math.max(right[i + 1], maxPrice - prices[i]);
        }

        
        int maxProfit = 0;
        for (int i = 0; i < n; i++) {
            maxProfit = Math.max(maxProfit, left[i] + right[i]);
        }

        return maxProfit;
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int[] prices = new int[n];
        
        for (int i = 0; i < n; i++) {
            prices[i] = sc.nextInt(); 
        }

        int result = findMaxProfit(prices, n);

        System.out.println(result);
    }
}
