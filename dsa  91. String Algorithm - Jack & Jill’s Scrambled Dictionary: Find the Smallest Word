91. String Algorithm - Jack & Jill’s Scrambled Dictionary: Find the Smallest Word

import java.util.*;

public class Main {

    public static void main(String[] args) 
    {

        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();

        while (T-- > 0) 
        {

            String P = sc.next();
            String S = sc.next();

            
            int[] freq = new int[26];

            for (char ch : S.toCharArray()) 
            {
                freq[ch - 'a']++;
            }

            StringBuilder result = new StringBuilder();

            for (char ch : P.toCharArray()) 
            {

                while (freq[ch - 'a'] > 0) 
                {
                    result.append(ch);
                    freq[ch - 'a']--;
                }
            }

            System.out.println(result.toString());
        }
    }
}
