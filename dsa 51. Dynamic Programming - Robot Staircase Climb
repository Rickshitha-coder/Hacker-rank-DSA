51. Dynamic Programming - Robot Staircase Climb

import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        
        Scanner sc=new Scanner(System.in);
        
        int n=sc.nextInt();//3
        
        if(n==1){
            System.out.println(n);
            return;
        }
        
        int a=1;
        int b=2;
        int c=0;
        
        for(int i=3;i<=n;i++)//3
        {
            c=a+b;//c=1+2=3
            a=b;//a=2
            b=c;//b=3
        }
        System.out.println(b);//b=3
    }
}
