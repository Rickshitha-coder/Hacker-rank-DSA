77. Backtracking - Find All Paths for a Rat in a Maze


import java.util.*;

public class Maze
{
    static List<String> mazeList = new ArrayList<>();
    
    static void solveMaze(int row,int col,int[][] maze,int n,String mString,boolean[][] visited)
    {
        //base case
        if(row == n-1 && col == n-1)
        {
            mazeList.add(mString);
            
            return;
        }
        
        //initial
        
        visited[row][col] = true;
        
        //down traversal
        if(isPath(row+1,col,maze,n,visited))
        {
            solveMaze(row+1,col,maze,n,mString+"D",visited);
        }
        
        //left traversal
        if(isPath(row,col-1,maze,n,visited))
        {
            solveMaze(row,col-1,maze,n,mString+"L",visited);
        }
        
        //right traversal
        if(isPath(row,col+1,maze,n,visited))
        {
            solveMaze(row,col+1,maze,n,mString+"R",visited);
        }
        
        //Up traversal
        if(isPath(row-1,col,maze,n,visited))
        {
            solveMaze(row-1,col,maze,n,mString+"U",visited);
        }
        
        visited[row][col] = false;
    }//solve method
    
    //is path method
    
    static boolean isPath(int row,int col,int[][] maze,int n,boolean[][] visited)
    {
        if(row>=0 && col>=0 && row<n && col<n && maze[row][col] == 1 && !visited[row][col])
        {
           return true; 
        }
        return false;
    }
    
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);
        
        int n = sc.nextInt();
        
        int[][] maze = new int[n][n];
        
        for(int i=0;i<n;i++)
        {
            for(int j=0;j<n;j++)
            {
                maze[i][j] = sc.nextInt();
            }
        }//for
        
        boolean[][] visited = new boolean[n][n];
        
        if(maze[0][0] == 1)
        {
            solveMaze(0,0,maze,n,"",visited); //row,col,maze array,n,outputstring,visited
            
        }
        
        System.out.println(mazeList);
    }
}
