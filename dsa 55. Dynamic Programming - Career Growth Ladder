55. Dynamic Programming - Career Growth Ladder


import java.util.*;

public class LongestSubsequence
{
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);
        
        int n = sc.nextInt();
        
        int[] sequence = new int[n];
        
        for(int i=0;i<n;i++)
        {
            sequence[i] = sc.nextInt();
        }
        
        int[] length = new int[n];
        
        for(int i=0;i<n;i++)
        {
            length[i] = 1;
        }
        
        //5 1 6 2 7 3 = sequence
        //1 1 1 1 1 = length//1 1 2 1 1 //1 1 2 2 1 1 //1 1 2 2 3 1
        for(int i=1;i<n;i++)//i=1//i=2//i=3//i=4
        {
            for(int j=0;j<i;j++)//j=0//j=1;1<1--> false//j=0//j=1
            {
                if(sequence[j] < sequence[i])//s[0] < s[1]//s[0] < s[2]//1< 6//s[0] < s[3]-->false//1 < 2//6<2-->false
                    //5 < 7
                {
                    length[i] = Math.max(length[i],length[j]+1);//1,1+1//length[2] =2//length[3]=1,2//length[4]=1,1+1=2
                    
                }
            }
        }
        
        int max = 0;
        
        for(int i=0;i<n;i++)
        {
            if(length[i] > max)
            {
                max = length[i];
            }
        }
        
        System.out.println(max);
    }
}
