89. String Algorithm - Secure Passphrase Validator: Check Rearrangeable Palindromes


import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.next();

        int[] freq = new int[256]; // ASCII support

        for (char c : s.toCharArray()) {
            freq[c]++;
        }

        int oddCount = 0;

        for (int f : freq) {
            if (f % 2 != 0) {
                oddCount++;
            }
        }

        if (oddCount <= 1) {
            System.out.println("Yes");
        } else {
            System.out.println("No");
        }
    }
}
