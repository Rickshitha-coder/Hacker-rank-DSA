66. Dynamic Programming - Splitting Expenses Equally

import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        int[] arr = new int[n];

        int totalSum = 0;
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
            totalSum += arr[i];
        }

        // If total sum is odd, cannot split equally
        if (totalSum % 2 != 0) {
            System.out.println("false");
            return;
        }

        int target = totalSum / 2;

        // DP array
        boolean[] dp = new boolean[target + 1];
        dp[0] = true; // sum 0 is always possible

        for (int num : arr) {
            for (int j = target; j >= num; j--) {
                dp[j] = dp[j] || dp[j - num];
            }
        }

        System.out.println(dp[target] ? "true" : "false");
    }
}
