92. String Algorithm - Similar Char

import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();
        String S = sc.next();

        // Prefix array
        int[][] prefix = new int[N + 1][26];

        // Build prefix counts
        for (int i = 1; i <= N; i++) {
            // Copy previous counts
            for (int j = 0; j < 26; j++) {
                prefix[i][j] = prefix[i - 1][j];
            }

            // Add current character
            char ch = S.charAt(i - 1);
            prefix[i][ch - 'a']++;
        }

        int Q = sc.nextInt();

        while (Q-- > 0) {
            int P = sc.nextInt();

            char ch = S.charAt(P - 1);
            int index = ch - 'a';

            // Count before position P
            System.out.println(prefix[P - 1][index]);
        }

        sc.close();
    }
}
