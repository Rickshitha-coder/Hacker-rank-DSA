50. Greedy Algorithm - Equal Stack Sum Game


import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        /*
        SAMPLE INPUT:
        5
        3 2 1 1 1
        3
        4 3 2
        4
        1 1 4 1

        EXPECTED OUTPUT:
        5
        */

        // Read number of elements in stack 1
        int n1 = sc.nextInt();   // 5
        int[] s1 = new int[n1];
        int sum1 = 0;

        // Read stack 1 elements and calculate sum
        for (int i = 0; i < n1; i++) {
            s1[i] = sc.nextInt();   // 3 2 1 1 1
            sum1 += s1[i];          // sum1 = 8
        }

        // Read number of elements in stack 2
        int n2 = sc.nextInt();   // 3
        int[] s2 = new int[n2];
        int sum2 = 0;

        // Read stack 2 elements and calculate sum
        for (int i = 0; i < n2; i++) {
            s2[i] = sc.nextInt();   // 4 3 2
            sum2 += s2[i];          // sum2 = 9
        }

        // Read number of elements in stack 3
        int n3 = sc.nextInt();   // 4
        int[] s3 = new int[n3];
        int sum3 = 0;

        // Read stack 3 elements and calculate sum
        for (int i = 0; i < n3; i++) {
            s3[i] = sc.nextInt();   // 1 1 4 1
            sum3 += s3[i];          // sum3 = 7
        }

        // Pointers (top of each stack)
        int i = 0, j = 0, k = 0;

        // Loop until sums become equal or stack becomes empty
        while (true) {

            // If any stack is empty  no solution
            if (i == n1 || j == n2 || k == n3) {//0==5 || 0==3|| 0==4  //0==5 1==3 0==4 //1==5 1==3 0==4 //1==5 1==3 1==4 //1==5 1==3 2==4
                System.out.println(0);
                return;
            }

            // If all sums are equal print answer
            if (sum1 == sum2 && sum2 == sum3) { //8==9 && 9==7  //8==5 && 5==7 //5==5 && 5==7 //5==5 && 5==6  //5==5 & 5-==5
                System.out.println(sum1); // Output: 5
                return;
            }

            // sum1 =8 sum2=9 sum3=7
            if (sum1 >= sum2 && sum1 >= sum3) {//8>=9 && 8>=7 --fail //8>=4 && 8>=7 //5>=5 && 5>=7 fail //5>=5 && 5>=6 fail
                // Remove top of stack1
                sum1 -= s1[i];   //8-=s1[0] = 8-3=5
                i++;             // 1
            }
            else if (sum2 >= sum1 && sum2 >= sum3) {//9>=8 && 9>=7 //5>=5 && 5>=7 fail //5>=5 5>=6
                // Remove top of stack2
                sum2 -= s2[j];//9-=s2[0]=9-4=5
                j++;//1
            }
            else {
                // Remove top of stack3
                sum3 -= s3[k];//7-s3[0] = 7-1 =6 //6-s[1]= 6-2=5
                k++;//1 //2
            }
        }
    }
}
