81. Backtracking - N-Queens Problem Solver

import java.io.*;
import java.util.*;

public class Solution {
    
    static void  solve(char[][] board,int row, int n)
    {
        if(row == n)
        {
            for(int i=0;i<n;i++)
            {
                System.out.println(new String(board[i]));
            }
            System.out.println();
            return;
        }
        
        for(int col=0;col<n;col++)
        {
            if(isSafe(board,row,col,n))
            {
              board[row][col] = 'Q';
                
              solve(board,row+1,n);//recursion
                
              board[row][col] = '.';//undo -- delete 
            }
        }//for loop
    }//method

    static boolean isSafe(char[][] board,int row,int col,int n)
    {
        //upward
        for(int i=0;i<row;i++)
        {
            if(board[i][col] == 'Q')
            {
                return false;
            }
        }
        //upward -left diagonal
        for(int i=row-1,j=col-1;i>=0&&j>=0;i--,j--)
        {
            if(board[i][j] == 'Q')
            {
                return false;
            }
        }
        //upward - right diagonal
        for(int i=row-1,j=col+1;i>=0&&j<n;i--,j++)
        {
            if(board[i][j] == 'Q')
            {
                return false;
            }
        }//loop
        return true; //safe means return true
    }
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        int n = sc.nextInt();
        
        char[][] board = new char[n][n];
        
        for(int i=0;i<n;i++)
        {
            Arrays.fill(board[i],'.');//fills with dots
        }
        solve(board,0,n); // array,row,n vlaue
        
    }
}
