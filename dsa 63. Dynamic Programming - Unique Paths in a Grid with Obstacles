63. Dynamic Programming - Unique Paths in a Grid with Obstacles


import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        
        Scanner sc=new Scanner (System.in);
        
        int m=sc.nextInt();//rows
        int n=sc.nextInt();//columns
        
        int[][] grid=new int[m][n];
        
        
        for (int i=0;i<m;i++)
        {
            for(int j=0;j<n;j++)
            {
                grid[i][j]=sc.nextInt();
            }
        }
        
        int[][] dp=new int[m][n];
        if(grid[0][0]==1 || grid[m-1][n-1]==1)
        {
            System.out.println(0);
            return;
        }
        
        dp[0][0]=1;//start
        
        
        for(int j=1; j < n;j++)
        {
            if(grid[0][j]==0)
            {
                dp[0][j]=dp[0][j-1];
            }
            else
            {
                dp[0][j]=0;
            }
        }
        
         for (int i = 1; i < m; i++) {
            if (grid[i][0] == 0)
                dp[i][0] = dp[i - 1][0];
            else
                dp[i][0] = 0;
        }
        
         for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {

                if (grid[i][j] == 0)
                    dp[i][j] = dp[i - 1][j] + dp[i][j - 1];
                else
                    dp[i][j] = 0;
            }
        }

        // Print result
        System.out.println(dp[m - 1][n - 1]);
        
        

    }
}
